Init()
{
	SendMessage("", "스크립트설정", "handleA " + $WorkingFile + ".type1");
	SendMessage("", "스크립트설정", "handleB " + $WorkingFile + ".type2");
	SendMessage("", "스크립트설정", "dummy " + "null");
	
	SetObjValue("OpenFlag", OPEN);
	SetObjValue("LockFlag", LOCK);
	SetObjValue("MotionName", "");
	
	SendMessage("", "애니메이션", "열기1");
}

type1.pick()
{
	return "잡기";
}

type1.click()
{
	$OpenFlag = GetObjValue("OpenFlag");
	$LockFlag = GetObjValue("LockFlag");
	
	if($LockFlag == LOCK)
	{
		SendMessage("사운드", "연주", "중앙통로문잠긴소리,data\sound\돌리는문잠긴것.wav");
		SendMessage("타이머", "스크립트설정", "0 0 1 _langtable.Text20");
	}
	else
	{
		switch($OpenFlag)
		{
			case 0:
			{
				SendMessage("", "애니메이션", "열기1");
				if(GetObjValue("MotionName") == "열기1")
				{
					SetObjValue("OpenFlag", $OpenFlag = 1);
				}
				return;
			}
			case 1:
			{
				SendMessage("", "애니메이션", "닫기1");
				if(GetObjValue("MotionName") == "닫기1")
				{
					SetObjValue("OpenFlag", $OpenFlag = 0);
				}
				return;
			}
			case 2:
			{
				SendMessage("", "애니메이션", "닫기2");
				if(GetObjValue("MotionName") == "닫기2")
				{
					SetObjValue("OpenFlag", $OpenFlag = 0);
				}
				return;
			}
		}
	} 
}

type2.pick()
{
	return "잡기";
}

type2.click()
{
	$OpenFlag = GetObjValue("OpenFlag");
	$LockFlag = GetObjValue("LockFlag");
	
	if($LockFlag == LOCK)
	{
		SendMessage("사운드", "연주", "중앙통로문잠긴소리,data\sound\돌리는문잠긴것.wav");
		SendMessage("타이머", "스크립트설정", "0 0 1 _langtable.Text20");
	}
	else
	{
		switch($OpenFlag)
		{
			case 0:
			{
				SendMessage("", "애니메이션", "열기2");
				if(GetObjValue("MotionName") == "열기2")
				{
					SetObjValue("OpenFlag", $OpenFlag = 2);
				}
				return;
			}
			case 1:
			{
				SendMessage("", "애니메이션", "닫기1");
				if(GetObjValue("MotionName") == "닫기1")
				{
					SetObjValue("OpenFlag", $OpenFlag = 0);
				}
				return;
			}
			case 2:
			{
				SendMessage("", "애니메이션", "닫기2");
				if(GetObjValue("MotionName") == "닫기2")
				{
					SetObjValue("OpenFlag", $OpenFlag = 0);
				}
				return;
			}
		}
	} 
}