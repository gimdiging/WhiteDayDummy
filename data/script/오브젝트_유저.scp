use()
{
	if($USER_RISE == TRUE)
	{
		SendMessage("자막", "문자출력", "3,여기서는 사용할 수 없다");
		return;
	}

	LoadObject("WObjStaticBody", "119", "*pos " + GetObjPos("유저") + " *rot 0.0 0.0 0.0 *pet data/puppet/char/캐릭터_성아.pet *scale 1.5");
	SendMessage("119", "위치", "" + GetObjPos("유저"));
	SendMessage("콘솔", "NOCLIP", "ON");
	SendMessage("119", "페이드", "Recursive 0 0 0");
	SendMessage("유저", "이동제한", "on");
	SendMessage("유저", "오르기", "119 머리");
	SendMessage("사운드", "연주", "data/sound/menu/cell_beep1.wav");
	SendMessage("타이머", "스크립트설정", "1 0 0 오브젝트_유저.useRelease");
}

useRelease()
{
	SendMessage("사운드", "연주", "data/sound/menu/cell_beep2.wav");
	DeleteObject("119");
	SendMessage("유저", "내려오기", "");
	SendMessage("콘솔", "NOCLIP", "OFF");
	SendMessage("유저", "이동제한", "off");
}