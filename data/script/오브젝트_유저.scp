Process()
{
	if($USER_RISE == OFF && $USER_CAPTUREITEM == TRUE)
	{
		$USER_CAPTUREITEM = FALSE;
		SendMessage("유저", "놓기", "팔");
		SendMessage("사운드", "연주", "당기는문잠긴것,data/sound/물건놓기.wav");
		SendMessage("작업용사다리", "캐쉬초기화", "");
	}
}

Event무섭게깔리는음악()
