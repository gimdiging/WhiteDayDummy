Init()
{
	SendMessage("", "스크립트설정", "item " + $WorkingFile);
	SetObjName("가정실습실열쇠");
	SetObjValue("Step", 0);
}

pick()
{
	$Step = GetObjValue("Step");
	
	if($Step == 0)
	{
		return "보기";
	}
	else if($Step == 1)
	{
		return "잡기";
	}
	return "";
}

click()
{
	$Step = GetObjValue("Step");
	
	if($Step == 0)
	{
//		SendMessage("자막", "문자출력", "2,There is a key inside the safe");
		SendMessage("타이머", "스크립트설정", "0 0 1 _langtable.Text38");
	}
	else if($Step == 1)
	{
		SendMessage("타이머", "스크립트설정", "0 0 1 아이템_가사실열쇠.GetItem");
	}
	SetObjValue("Step", $Step + 1);
}

GetItem()
{
	SendMessage("가정실습실열쇠", "페이드", "Recursive 1 1 0");
	SendMessage("유저", "획득", "가정실습실열쇠");
	SendMessage("타이머", "스크립트설정", "0 0 1 _langtable.Text39");
	SendMessage("타이머", "스크립트설정", "1 0 1 아이템_가사실열쇠.Release");
}

Release()
{
	DeleteObject("가정실습실열쇠");
}
