Init()
{
	SetObjName("나무아랫쪽");
	SendMessage("배경", "켜기", "tree_down");
	for($i = 1; $i <= 9; $i++)
	{
		SendMessage("", "스크립트설정", "egg" + $i + " " + $WorkingFile + ".egg" + $i);
		SetObjValue("EggDead" + $i , FALSE);
	}
	SetObjValue("DeadCount", 4);
	SetObjValue("DeadEggName", "");
	SetObjValue("FadeStep", 255);

	SendMessage("사운드", "연주3d", GetObjPos("나무아랫쪽") + " loop,모기소리,data/sound/event/모기앵앵.wav");
}

egg1.pick()
{
	return (GetObjValue("EggDead1") == FALSE && GetObjValue("UserItem") == "용제") ? "i용제" : "";
}

egg1.click()
{
	if(GetObjValue("UserItem") == "용제" && GetObjValue("EggDead1") == FALSE)
	{
		SetObjValue("EggDead1", TRUE);
		SetObjValue("DeadEggName", "GeoSphere10");
		SendMessage("타이머", "스크립트설정", "0 0 1 e_나무아랫쪽.FadeOut0 *obj 나무아랫쪽");
	}
}

