}

e모기1()
{
	SetObjValue("모기공격", OFF);
}

e모기2()
{
	SetObjValue("모기공격", OFF);
}

e모기3()
{
	if(GetObjValue("모기공격") == OFF)
	{
		SetObjValue("모기공격", ON);
		e모기공격();
	}
}

e모기공격()
{
	if(GetObjValue("모기공격") == ON)
	{
		if(GetObjValue("UserItem") == "모기약")
		{
			SendMessage("자막", "활성화", "");
			SendMessage("자막", "와이드모드", "켜기");	

			SendMessage("사운드", "연주", "data/sound/모기약.wav");
//			SendMessage("자막", "문자출력", "2,다죽어버려~~~");
			SendMessage("타이머", "스크립트설정", "0 0 1 _langtable.Text01");

			LoadObject("WObjGas", "모기약연기", GetCameraInfo() + " *aabb -60 -60 -30 60 60 30 *velocity 4");
			SendMessage("타이머", "스크립트설정", "2 0 1 e_나무아랫쪽.e모기약죽이기 *obj 나무아랫쪽");

			SendMessage("타이머", "스크립트설정", "6 0 1 e_나무아랫쪽.e모기공격 *obj 나무아랫쪽");
		}
		else
		{
			SendMessage("유저", "공격", "");
//			SendMessage("자막", "문자출력", "1,앗! 따가워~~, 모기약이 필요해~~~");
			SendMessage("타이머", "스크립트설정", "0 0 1 _langtable.Text02");

			SendMessage("타이머", "스크립트설정", "2 0 1 e_나무아랫쪽.e모기공격 *obj 나무아랫쪽");
		}
	}
}

e모기약죽이기()
{
	DeleteObject("모기약연기");
	SendMessage("자막", "비활성", "");
	SendMessage("자막", "와이드모드", "끄기");	
}